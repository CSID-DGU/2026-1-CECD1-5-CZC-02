# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Backend API Configuration
BACKEND_URL=http://localhost:8080

# AI Engine
# rule: existing rule-based analyzer
# ollama: rule-based analyzer + local Ollama LLM enhancement
AI_ENGINE=rule
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_TEMPERATURE=0.1

# Embedding Classifier
# true: use open-source BGE-M3 embedding model for mail/action classification
# false: use rule-based analyzer only
EMBEDDING_CLASSIFIER_ENABLED=false
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_ACTION_THRESHOLD=0.52
EMBEDDING_BUSINESS_THRESHOLD=0.50

# Entity Extractor
# true: use GLiNER open-source NER model for customer/product/attendee hints
# false: use rule-based extraction only
GLINER_ENABLED=false
GLINER_MODEL_NAME=urchade/gliner_multi-v2.1
GLINER_THRESHOLD=0.35
